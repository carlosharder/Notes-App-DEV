web: bash -c "if [ -d notes ] && [ \"$NOTES_DIR\" != \"\" ] && [ \"$NOTES_DIR\" != \"notes\" ]; then mkdir -p $NOTES_DIR/images && cp -n notes/*.md $NOTES_DIR/ 2>/dev/null; cp -n notes/images/* $NOTES_DIR/images/ 2>/dev/null; fi; gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --access-logfile -"
